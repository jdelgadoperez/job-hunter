{
  "name": "job-hunter",
  "version": "0.6.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "bin": {
    "job-hunter": "bin/job-hunter"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:web": "vitest run --config web/vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json",
    "dev": "node --import tsx scripts/dev.ts",
    "dev:web": "vite web",
    "build:web": "vite build web",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "setup": "node --import tsx scripts/setup.ts",
    "cli": "node --import tsx src/cli/main.ts",
    "serve": "node --import tsx src/cli/main.ts serve",
    "smoke": "node --import tsx scripts/smoke-connectors.ts",
    "smoke:scorer": "node --import tsx scripts/smoke-scorer.ts",
    "smoke:airtable": "node --import tsx scripts/smoke-airtable.ts",
    "smoke:postgres": "node --import tsx scripts/smoke-postgres.ts",
    "smoke:scan": "node --import tsx scripts/smoke-scan.ts",
    "smoke:advisor": "node --import tsx scripts/smoke-advisor.ts",
    "scan:worker": "node --import tsx src/backend/scanner/main.ts",
    "analyze:directory": "node --import tsx scripts/analyze-directory.ts",
    "analyze:custom-domains": "node --import tsx scripts/probe-custom-domains.ts",
    "build:skill-seed": "node --import tsx scripts/build-skill-seed.ts",
    "check:wiki-links": "node --import tsx scripts/check-wiki-links.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@hono/node-server": "^2.0.6",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.31",
    "lucide-react": "^1.25.0",
    "mammoth": "^1.12.0",
    "p-limit": "^7.3.1",
    "pdfjs-dist": "^6.0.227",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  }
}
