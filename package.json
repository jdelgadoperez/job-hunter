{
  "name": "job-hunter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "cli": "node --import tsx src/cli/main.ts",
    "smoke": "node --import tsx scripts/smoke-connectors.ts",
    "smoke:scorer": "node --import tsx scripts/smoke-scorer.ts",
    "smoke:airtable": "node --import tsx scripts/smoke-airtable.ts",
    "smoke:scan": "node --import tsx scripts/smoke-scan.ts",
    "build:skill-seed": "node --import tsx scripts/build-skill-seed.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "playwright": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "better-sqlite3": "^11.3.0",
    "mammoth": "^1.12.0",
    "p-limit": "^7.3.0",
    "pdfjs-dist": "^6.0.227",
    "zod": "^4.4.3"
  }
}
